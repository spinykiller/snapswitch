{
  "name": "snapswitch-vscode",
  "displayName": "SnapSwitch Projects",
  "description": "Switch between multiple VS Code project windows instantly — one click or Cmd+1-9. No more 3-click context switching.",
  "version": "4.0.2",
  "publisher": "JYashSakariyaJain",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spinykiller/snapswitch"
  },
  "bugs": {
    "url": "https://github.com/spinykiller/snapswitch/issues"
  },
  "homepage": "https://github.com/spinykiller/snapswitch#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Keymaps",
    "Snippets"
  ],
  "keywords": [
    "project",
    "switch",
    "workspace",
    "tabs",
    "snapswitch",
    "manager",
    "context switching",
    "multi-project",
    "productivity",
    "window",
    "mac"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:snapswitch.sidebarView",
    "onView:snapswitch.projectsTree",
    "onCommand:snapswitch.switchProject",
    "onCommand:snapswitch.focus",
    "onCommand:snapswitch.openProject"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "snapswitchContainer",
          "title": "SnapSwitch",
          "icon": "activity_icon.svg"
        }
      ]
    },
    "views": {
      "snapswitchContainer": [
        {
          "type": "webview",
          "id": "snapswitch.sidebarView",
          "name": "Projects"
        },
        {
          "type": "tree",
          "id": "snapswitch.projectsTree",
          "name": "Pinned Projects"
        }
      ]
    },
    "commands": [
      {
        "command": "snapswitch.addProject",
        "title": "SnapSwitch: Pin Current Project"
      },
      {
        "command": "snapswitch.switchProject",
        "title": "SnapSwitch: Switch Project"
      },
      {
        "command": "snapswitch.focus",
        "title": "SnapSwitch: Show Dashboard"
      },
      {
        "command": "snapswitch.openProject",
        "title": "SnapSwitch: Open Project"
      },
      {
        "command": "snapswitch.openProject1",
        "title": "SnapSwitch: Open Project 1"
      },
      {
        "command": "snapswitch.openProject2",
        "title": "SnapSwitch: Open Project 2"
      },
      {
        "command": "snapswitch.openProject3",
        "title": "SnapSwitch: Open Project 3"
      },
      {
        "command": "snapswitch.openProject4",
        "title": "SnapSwitch: Open Project 4"
      },
      {
        "command": "snapswitch.openProject5",
        "title": "SnapSwitch: Open Project 5"
      },
      {
        "command": "snapswitch.openProject6",
        "title": "SnapSwitch: Open Project 6"
      },
      {
        "command": "snapswitch.openProject7",
        "title": "SnapSwitch: Open Project 7"
      },
      {
        "command": "snapswitch.openProject8",
        "title": "SnapSwitch: Open Project 8"
      },
      {
        "command": "snapswitch.openProject9",
        "title": "SnapSwitch: Open Project 9"
      },
      {
        "command": "snapswitch.openTerminal",
        "title": "SnapSwitch: Open Terminal"
      }
    ],
    "keybindings": [
      {
        "command": "snapswitch.openProject1",
        "key": "cmd+1",
        "mac": "cmd+1",
        "when": "editorTextFocus || !editorTextFocus"
      },
      {
        "command": "snapswitch.openProject2",
        "key": "cmd+2",
        "mac": "cmd+2",
        "when": "editorTextFocus || !editorTextFocus"
      },
      {
        "command": "snapswitch.openProject3",
        "key": "cmd+3",
        "mac": "cmd+3",
        "when": "editorTextFocus || !editorTextFocus"
      },
      {
        "command": "snapswitch.openProject4",
        "key": "cmd+4",
        "mac": "cmd+4",
        "when": "editorTextFocus || !editorTextFocus"
      },
      {
        "command": "snapswitch.openProject5",
        "key": "cmd+5",
        "mac": "cmd+5",
        "when": "editorTextFocus || !editorTextFocus"
      },
      {
        "command": "snapswitch.openProject6",
        "key": "cmd+6",
        "mac": "cmd+6",
        "when": "editorTextFocus || !editorTextFocus"
      },
      {
        "command": "snapswitch.openProject7",
        "key": "cmd+7",
        "mac": "cmd+7",
        "when": "editorTextFocus || !editorTextFocus"
      },
      {
        "command": "snapswitch.openProject8",
        "key": "cmd+8",
        "mac": "cmd+8",
        "when": "editorTextFocus || !editorTextFocus"
      },
      {
        "command": "snapswitch.openProject9",
        "key": "cmd+9",
        "mac": "cmd+9",
        "when": "editorTextFocus || !editorTextFocus"
      },
      {
        "command": "snapswitch.openTerminal",
        "key": "cmd+`",
        "mac": "cmd+`",
        "when": "editorTextFocus || !editorTextFocus"
      },
      {
        "command": "snapswitch.openTerminal",
        "key": "cmd+₹",
        "mac": "cmd+₹",
        "when": "editorTextFocus || !editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "snapswitch.switchProject",
          "when": "view == snapswitch.sidebarView",
          "group": "navigation"
        },
        {
          "command": "snapswitch.addProject",
          "when": "view == snapswitch.sidebarView",
          "group": "navigation"
        },
        {
          "command": "snapswitch.addProject",
          "when": "view == snapswitch.projectsTree",
          "group": "navigation"
        },
        {
          "command": "snapswitch.switchProject",
          "when": "view == snapswitch.projectsTree",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "SnapSwitch",
      "properties": {
        "projectTabs.projects": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "group": {
                "type": "string",
                "description": "Optional group/tag for the project"
              },
              "icon": {
                "type": "string",
                "description": "Optional codicon identifier (e.g. 'star', 'code')"
              },
              "color": {
                "type": "string",
                "description": "Optional ThemeColor ID or hex value"
              }
            }
          }
        },
        "projectTabs.showRecentProjects": {
          "type": "boolean",
          "default": true,
          "description": "Show an automatically collected list of recently opened projects in the SnapSwitch view."
        },
        "projectTabs.position": {
          "type": "string",
          "default": "left",
          "enum": [
            "left",
            "right"
          ],
          "description": "Where pinned projects should render inside the SnapSwitch view."
        },
        "projectTabs.statusBarMaxItems": {
          "type": "number",
          "default": 6,
          "minimum": 0,
          "maximum": 20,
          "description": "How many pinned projects to show as one-click buttons in the status bar. Set to 0 to disable."
        }
      }
    }
  }
}